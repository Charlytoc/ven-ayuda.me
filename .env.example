# Unique suffix appended to every Docker container name (e.g. django-ven-ayuda).
# Use a distinct value if you run multiple stacks on the same machine.
CONTAINER_SUFFIX=ven-ayuda

# Django Configuration
DEBUG=1
SECRET_KEY=django-insecure-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django

# Database Configuration
POSTGRES_DB=startup-db
POSTGRES_USER=startup-user
POSTGRES_PASSWORD=startup_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Ports (override if defaults conflict with other local services)
# Host-side publish ports only (inside the network: Postgres 5432, Redis 6379, Flower 5555)
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# FLOWER_HOST_PORT=5555
DJANGO_PORT=8000

# Public URL of the Django API. Use ngrok/devtunnel HTTPS in dev if you need a public URL.
# Its hostname is added to ALLOWED_HOSTS automatically (e.g. *.ngrok-free.dev).
SITE_URL=http://127.0.0.1:8000
# Optional: comma-separated extra hosts (tunnel renames, staging domains, …).
# ALLOWED_HOSTS=other.example.com
REALTIME_PORT=3001
WEB_PORT=3000
# Single host port for the Nginx reverse proxy — the one URL you share via tunnel.
# Routes: /api/ + /admin/ → Django  |  /realtime/ → realtime server  |  / → Next.js
ENTRYPOINT_PORT=9000

# URLs the browser uses to reach the API and realtime server.
# Required — `./taskfile.sh web` will refuse to start without these.
# Point at Nginx (ENTRYPOINT_PORT) so everything flows through one entry point.
# WEB_API_URL must include the /api path. WEB_REALTIME_URL is host-only —
# socket.io always connects to /socket.io/ on that host regardless of path.
# For a tunnel: replace localhost:9000 with your tunnel domain.
WEB_API_URL=http://localhost:9000/api
WEB_REALTIME_URL=http://localhost:9000

# Redis Configuration (TCP port is always 6379 in app code; set host/URLs for AWS, etc.)
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# Celery Configuration (broker = Redis; task results = Postgres via django-celery-results)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

# Django Superuser Configuration (for automatic creation)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@localhost.com
DJANGO_SUPERUSER_PASSWORD=p


# External API Keys
# Required for the AI tutor (OpenAI Responses API + Whisper/image helpers).
OPENAI_API_KEY=
# Required for conversation audio generation (listen_and_respond tasks).
ELEVENLABS_API_KEY=

# Frontend URL — used to build absolute links / redirects.
FRONTEND_URL=http://localhost:3000